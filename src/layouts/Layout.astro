---
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';

import '../index.css';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://verifiedpropfirm.com');
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/images/logo.webp" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Performance: Preload Critical Assets -->
    <link rel="preload" href="/images/logo.webp" as="image" type="image/png" />
    {image && <link rel="preload" href={image} as="image" />}
    
    <SEO 
      title={title} 
      description={description} 
      canonicalURL={canonicalURL}
      image={image}
    />
    
    <Schema type="Organization" data={{}} />
    
    <slot name="head" />
  </head>
  <body class="bg-slate-950 text-slate-50 selection:bg-blue-500/30">
    <slot />
  </body>
</html>
