      <div class="flex items-center gap-3">
        <img src="/images/logo.webp" alt="VerifiedPropFirm Logo" class="h-8 w-auto grayscale opacity-80" />
        <span class="text-xl font-bold tracking-tight text-slate-300">VerifiedPropFirm<span class="text-slate-500">.com</span></span>
      </div>
      <div class="flex gap-6 text-slate-400 text-sm flex-wrap justify-center md:justify-end">
        <a href="/about/" class="hover:text-slate-300 transition-colors">About</a>
        <a href="/blog/" class="hover:text-slate-300 transition-colors">Blog</a>
        <a href="/services/" class="hover:text-slate-300 transition-colors">Services</a>
        <a href="/terms/" class="hover:text-slate-300 transition-colors">Terms</a>
