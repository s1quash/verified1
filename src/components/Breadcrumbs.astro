---
interface Item {
  name: string;
  url: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": `https://verifiedpropfirm.com${item.url}`
  }))
};
---

<nav aria-label="Breadcrumb" class="flex mb-8">
  <ol class="flex items-center space-x-2 text-sm text-slate-500">
    <li>
      <a href="/" class="hover:text-blue-400 transition-colors flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Home
      </a>
    </li>
    {items.map((item, index) => (
      <li class="flex items-center space-x-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700"><path d="m9 18 6-6-6-6"/></svg>
        <a 
          href={item.url} 
          class={`hover:text-blue-400 transition-colors ${index === items.length - 1 ? 'text-slate-300 font-medium pointer-events-none' : ''}`}
          aria-current={index === items.length - 1 ? 'page' : undefined}
        >
          {item.name}
        </a>
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
