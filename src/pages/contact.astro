---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Contact Us | VerifiedPropFirm" description="Have questions about a prop firm discount or our custom EA tools? Get in touch with the VerifiedPropFirm team.">
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer slot="head"></script>
  <div class="min-h-screen bg-slate-950 text-slate-50 font-sans">
    <Header />
    <main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <h1 class="text-4xl font-extrabold mb-4 text-gradient">Contact Us</h1>
      <p class="text-slate-400 mb-8">Have a question about a discount code, want to request a custom EA, or need help? Drop us a message and we'll get back to you.</p>
      <div id="contact-container" class="bg-slate-900/80 p-8 rounded-2xl border border-slate-800 shadow-xl">
        <form id="contact-form" action="https://verifiedpropfirm.com/submit" method="POST" class="space-y-6">
          <input type="hidden" name="form-name" value="contact-form" />
          <input type="hidden" name="_subject" value="New Contact Form Submission!" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2">Name</label>
            <input type="text" name="name" required class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-3 text-slate-50 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" placeholder="John Doe" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2">Email</label>
            <input type="email" name="email" required class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-3 text-slate-50 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" placeholder="john@example.com" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2">Message</label>
            <textarea name="message" required rows="5" class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-3 text-slate-50 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" placeholder="Your message..."></textarea>
          </div>

          <!-- Cloudflare Turnstile -->
          <div class="cf-turnstile py-2" data-sitekey="0x4AAAAAADMraoaqaakRPjqQ" data-theme="dark"></div>

          <button type="submit" class="w-full premium-button bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 flex items-center justify-center gap-2 group transition-all">
            <span id="contact-button-text">Send Message</span>
            <span id="contact-loading" class="hidden">
              <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </span>
            <svg id="contact-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 group-hover:-translate-y-0.5 transition-transform"><line x1="22" y1="2" x2="11" y2="13"/><polyline points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
          <p class="text-center text-xs text-slate-500 mt-6">Or email us directly at <a href="mailto:support@verifiedpropfirm.com" class="text-blue-400 hover:underline">support@verifiedpropfirm.com</a></p>
        </form>

        <div id="contact-success" class="hidden text-center py-10 animate-fade-in">
          <div class="w-20 h-20 bg-blue-500/20 text-blue-400 rounded-full flex items-center justify-center mx-auto mb-6 shadow-[0_0_30px_rgba(59,130,246,0.1)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"></path><path d="M22 2l-7 20-4-9-9-4 20-7z"></path></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">Message Sent!</h3>
          <p class="text-slate-400 max-w-xs mx-auto leading-relaxed">
            Thank you for reaching out. We've received your message and will get back to you at your provided email address shortly.
          </p>
        </div>
      </div>

      <script is:inline>
        const cForm = document.getElementById('contact-form');
        const cSuccess = document.getElementById('contact-success');
        const cBtnText = document.getElementById('contact-button-text');
        const cLoading = document.getElementById('contact-loading');
        const cIcon = document.getElementById('contact-icon');

        if (cForm) {
          cForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            cBtnText.classList.add('hidden');
            cIcon.classList.add('hidden');
            cLoading.classList.remove('hidden');
            cForm.style.opacity = '0.5';
            cForm.style.pointerEvents = 'none';

            const formData = new FormData(cForm);
            const data = {
              form_name: "Contact Us Form",
              name: formData.get('name'),
              email: formData.get('email'),
              message: formData.get('message')
            };
            
            try {
              const response = await fetch(cForm.action, {
                method: 'POST',
                body: JSON.stringify(data),
                headers: { 
                  'Content-Type': 'application/json',
                  'Accept': 'application/json' 
                }
              });

              const result = await response.json();

              if (response.ok || result.success) {
                cForm.classList.add('hidden');
                cSuccess.classList.remove('hidden');
              } else {
                throw new Error('Failed');
              }
            } catch (error) {
              alert('Failed to send message. Please try again or email us directly.');
              cForm.style.opacity = '1';
              cForm.style.pointerEvents = 'auto';
              cBtnText.classList.remove('hidden');
              cIcon.classList.remove('hidden');
              cLoading.classList.add('hidden');
            }
          });
        }
      </script>
    </main>
    <Footer />
  </div>
</Layout>
