            <div class="overflow-x-auto bg-slate-900/50 rounded-xl border border-slate-800 mb-12 shadow-lg">
            <table class="w-full text-left text-sm text-slate-300">
            <thead class="bg-slate-800 text-white text-xs uppercase font-bold">
            <tr>
            <th class="px-6 py-4 rounded-tl-xl">Prop Firm</th>
            <th class="px-6 py-4 border-l border-slate-700">Max Time Limit</th>
            <th class="px-6 py-4 border-l border-slate-700">Min. Trading Days</th>
            <th class="px-6 py-4 border-l border-slate-700">Drawdown Type</th>
            <th class="px-6 py-4 border-l border-slate-700 rounded-tr-xl">Best Feature</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-slate-800">
            <tr class="hover:bg-slate-800/30 transition-colors">
            <td class="px-6 py-4 font-bold text-blue-400 font-bold text-emerald-400">FXIFY (Pro)</td>
            <td class="px-6 py-4 border-l border-slate-800 text-emerald-400 font-bold">Unlimited</td>
            <td class="px-6 py-4 border-l border-slate-800">5 Days</td>
            <td class="px-6 py-4 border-l border-slate-800 font-bold text-emerald-400">100% Static</td>
            <td class="px-6 py-4 border-l border-slate-800">On-Demand Payouts</td>
            </tr>
