              </nav>

              <div class="mt-12 pt-8 border-t border-slate-800">
                <div class="bg-blue-600/10 rounded-2xl p-6 border border-blue-500/20">
                  <h4 class="text-blue-400 font-bold text-xs uppercase tracking-widest mb-3 text-center">Exclusive Offer</h4>
                  <p class="text-xs text-slate-400 text-center mb-4 leading-relaxed">Lower your challenge costs instantly with our verified partner codes.</p>
                  <a href="/prop-firms/fxify" rel="sponsored" class="block bg-blue-600 text-white text-center font-bold py-3 rounded-xl text-xs hover:bg-blue-500 transition-all">Get Promo Codes →</a>
