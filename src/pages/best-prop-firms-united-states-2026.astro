            <section class="mt-20 pt-12 border-t border-slate-800">
              <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                <span class="text-blue-500">📚</span> Primary Sources & Regulatory References
              </h3>
              <ul class="space-y-4 text-sm text-slate-400 list-none p-0">
                <li class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4">
                  <span class="font-bold text-slate-300 min-w-[80px]">CFTC:</span>
